<script>
    document.addEventListener("DOMContentLoaded", function () {
        //クリックイベント
        document.querySelectorAll(".js-accordion-trigger").forEach(function(trigger) {
            trigger.addEventListener("click", function() {
                this.classList.toggle("is-open");
                let content = this.nextElementSibling;
                if (content.style.display === "none" || content.style.display === "") {
                    content.style.display = "block";
                } else {
                    content.style.display = "none";
                }
            });
        });

        // ナビの閉じるボタン
        let closeBtn = document.querySelector(".js-globalNav__close");
        if (closeBtn) {
            closeBtn.addEventListener("click", function () {
                let globalNav = document.querySelector(".l-globalNav");
                if (globalNav.style.display === "none") {
                    globalNav.style.display = "block";
                } else {
                    globalNav.style.display = "none";
                }
            });
        }
    });
</script>
