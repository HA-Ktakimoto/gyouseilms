<script>
    document.addEventListener("DOMContentLoaded", function () {

        // 「トップへ戻る」ボタン
        let backToTop = document.getElementById("backToTop");

        if (backToTop) {
            backToTop.addEventListener("click", function (event) {
                event.preventDefault();
                console.log("トップへ戻るボタンクリック"); 

                //スクロールをゆっくり
                window.scrollTo({
                    top: 0,
                    behavior: "smooth"
                });
            });
        } else {
            console.log("backToTopボタンが見つかりません");//入れないと動かない
        }

        // グローバルナビゲーショントグル
        let footGnavTrigger = document.querySelector(".js-foot-gnav-tigger");
        let globalNav = document.querySelector(".l-globalNav");

        if (footGnavTrigger && globalNav) {
            // スマホ表示の時のみ初期状態は非表示
            if (window.innerWidth <= 896) {
                globalNav.style.display = "none";
            }

            footGnavTrigger.addEventListener("click", function (event) {
                event.preventDefault();

                // .l-globalNavのdisplayをblockに切り替え
                if (globalNav.style.display === "block") {
                    globalNav.style.display = "none";
                } else {
                    globalNav.style.display = "block";
                }
            });
        }
    });
</script>

